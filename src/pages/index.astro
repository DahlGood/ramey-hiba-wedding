---
import BaseLayout from '../layouts/BaseLayout.astro';
import DateLocationSplit from '../components/DateLocationSplit.astro';
---

<BaseLayout title="Ramey & Hiba — May 7, 2026 in Rabat, Morocco">
  <DateLocationSplit />

  <section class="section section--narrow">
    <h2 class="section-title">Welcome to Rabat</h2>
    <div class="section-body">
      <p>We are so excited to celebrate our wedding with you in Morocco!</p>
      <p>
        Having our favorite people together in such a beautiful place means the world to us.
        This website has everything you need to plan your trip, from arrival tips to local
        travel notes and important details for the wedding weekend.
      </p>
      <p>We cannot wait to celebrate, explore, dance, and make unforgettable memories with you.</p>
    </div>
  </section>

  <section class="wedding-day">
    <h2 class="section-title">Wedding Day</h2>
    <p class="wedding-day__detail">May 7, 2026</p>
    <p class="wedding-day__detail">5:00 PM&ndash;5:00 AM</p>

    <div class="wedding-day__venue">
      <p class="wedding-day__detail">Villa Azzaitoune</p>
      <p class="wedding-day__address">
        33&deg;49&prime;40.5&Prime;N 6&deg;48&prime;59.9&Prime;W, El Menzeh, Morocco, Rabat, Morocco
      </p>
    </div>
  </section>
</BaseLayout>
